{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Today",
  "version": "0.1.0",
  "identifier": "com.today.client",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Today",
        "width": 800,
        "height": 600
      }
    ],
    "security": {
      "capabilities": ["default"],
      "freezePrototype": true,
      "csp": {
        "default-src": "'self'",
        "connect-src": "'self' ipc: http://ipc.localhost https://*.supabase.co wss://*.supabase.co",
        "font-src": "'self' data:",
        "img-src": "'self' data: blob: https://*.supabase.co",
        "object-src": "'none'",
        "base-uri": "'none'",
        "frame-ancestors": "'none'",
        "script-src": "'self'",
        "style-src": "'self' 'unsafe-inline'"
      },
      "devCsp": {
        "default-src": "'self'",
        "connect-src": "'self' ipc: http://ipc.localhost ws://localhost:1420 ws://localhost:1421 https://*.supabase.co wss://*.supabase.co",
        "font-src": "'self' data:",
        "img-src": "'self' data: blob: https://*.supabase.co",
        "object-src": "'none'",
        "base-uri": "'none'",
        "frame-ancestors": "'none'",
        "script-src": "'self'",
        "style-src": "'self' 'unsafe-inline'"
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "macOS": {
      "entitlements": "./Entitlements.plist"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
